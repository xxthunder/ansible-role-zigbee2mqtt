---
# yamllint config for the standalone zigbee2mqtt role.
# Mirrors the author's other roles' relaxed style.
extends: default

rules:
  braces:
    max-spaces-inside: 1
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  line-length: disable
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy: disable
